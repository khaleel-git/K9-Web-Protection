# Python
__pycache__/
*.exe

# Virtual Environment
venv/
.venv/

# PyInstaller build files and executables
build/
dist/
*.spec

# Un-ignore the Windows app installer scripts inside build/windows/
# (the root build/ rule above would otherwise catch them)
!windows/app/build/
!windows/app/build/windows/
!windows/app/build/windows/wails.exe.manifest
!windows/app/build/windows/installer/
!windows/app/build/windows/installer/project.nsi
!windows/app/build/windows/installer/setup-system.ps1
!windows/app/build/windows/installer/teardown-system.ps1
.DS_Store

# Compiled Go binaries
mac/app/k9webprotection
mac/app/k9
windows/k9webprotection.exe
