{
  "manifest_version": 3,
  "name": "K9 Web Protection — Porn & Adult Content Blocker",
  "short_name": "K9 Protection",
  "version": "2.2.0",
  "description": "Block porn, adult content & social media. Focus Mode for students. Free parental control filter for Chrome.",

  "permissions": [
    "storage",
    "declarativeNetRequest",
    "tabs",
    "webNavigation"
  ],

  "host_permissions": ["<all_urls>"],

  "background": {
    "service_worker": "background.js",
    "type": "module"
  },

  "action": {
    "default_popup": "popup.html",
    "default_title": "K9 Web Protection",
    "default_icon": {
      "16":  "icons/icon16.png",
      "32":  "icons/icon32.png",
      "48":  "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "run_at": "document_start",
      "all_frames": false
    }
  ],

  "declarative_net_request": {
    "rule_resources": [
      {
        "id": "k9_blocklist",
        "enabled": true,
        "path": "rules.json"
      }
    ]
  },

  "web_accessible_resources": [
    {
      "resources": ["blocked.html", "blocked.css", "blocked.js", "icons/*.png"],
      "matches": ["<all_urls>"]
    }
  ],

  "icons": {
    "16":  "icons/icon16.png",
    "32":  "icons/icon32.png",
    "48":  "icons/icon48.png",
    "128": "icons/icon128.png"
  },

  "homepage_url": "https://k9.khaleel.eu",

  "minimum_chrome_version": "102"
}
